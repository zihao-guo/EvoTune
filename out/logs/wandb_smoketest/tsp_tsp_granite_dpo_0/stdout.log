    connection_weights = np.array([0.5, 1.0, 1.5, 2.0])  # Initial weights. Adjust as needed.
    learning_factor = 0.01  # Learning rate for dynamic weights

    # Initialize heuristic matrix with zeros
    heuristic_matrix = np.zeros_like(distance_matrix)

    # Calculate dynamic weights for each connection
    for i in range(num_nodes):
        for j in range(i+1, num_nodes):
            weight_i = connection_weights[0] * np.exp(learning_factor * np.sum(distance_matrix[i, :]))  # Learning factor for higher-weight connections
            weight_j = connection_weights[1] * np.exp(learning_factor * np.sum(distance_matrix[j, :]))
            weighted_sum = (distance_matrix[i, j] * weight_i) + (distance_matrix[i, j] * weight_j)

            # Consider the path length around the edge
            path_length_i = np.sum(distance_matrix[np.delete(np.arange(num_nodes), [i, j])])
            path_length_j = np.sum(distance_matrix[np.delete(np.arange(num_nodes), [i, j])])
            combined_path_length = (path_length_i + path_length_j) / 2

            # Consider neighbor pheromone levels
            neighbors_i = np.delete(np.arange(num_nodes), i)
            neighbors_j = np.delete(np.arange(num_nodes), j)
            heuristic_neighbor_i = np.mean(distance_matrix[neighbors_i]) if neighbors_i.size > 0 else 0
            heuristic_neighbor_j = np.mean(distance_matrix[neighbors_j]) if neighbors_j.size > 0 else 0
            combined_neighbor_phero = (heuristic_neighbor_i + heuristic_neighbor_j) / 2

            heuristic_matrix[i, j] = heuristic_matrix[j, i] = weighted_sum + combined_path_length + combined_neighbor_phero

    return heuristic_matrix
