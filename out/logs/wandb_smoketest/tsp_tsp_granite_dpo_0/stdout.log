    for i in range(n):
        for j in range(n):
            E[i, j] = D[i, j] - D[i, j] * (D[i, j] <= D[j, i])

    # Step 2: Relax edges
    for _ in range(n - 1):
        E_copy = E.copy()
        for i in range(n):
