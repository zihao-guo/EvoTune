    num_nodes = distance_matrix.shape[0]
    # Compute local clustering coefficient for each node
    local_clustering_coefficients = []
    for i in range(num_nodes):
        # Calculate the number of edges between neighbors of node i
        neighbor_pairs = [(j, k) for j in range(num_nodes) for k in range(num_nodes) if distance_matrix[j, i] > 0 and distance_matrix[k, i] > 0 and j!= k]
        # Count the number of edges between neighbors of node i
        n_ij = sum(1 for j, k in neighbor_pairs if distance_matrix[j, k] > 0)
        # Count the total possible edges between neighbors of node i
        potential_edges = num_nodes * (num_nodes - 1) // 2 - n_ij
        # Compute the local clustering coefficient
        clustering_coefficient = 2.0 * n_ij / potential_edges if potential_edges > 0 else 0
        local_clustering_coefficients.append(clustering_coefficient)

    # Compute a heuristic value for each edge
    heuristic_matrix = distance_matrix.copy()
    for i in range(num_nodes):
        for j in range(i, num_nodes):  # Symmetric heuristics for edges ij and ji
            weight = distance_matrix[i, j] + max(local_clustering_coefficients[i], local_clustering_coefficients[j])
            heuristic_matrix[i, j] = heuristic_matrix[j, i] = weight

    return heuristic_matrix
