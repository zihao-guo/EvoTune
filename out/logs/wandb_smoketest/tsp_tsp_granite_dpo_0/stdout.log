    # Ensure the input is a numpy array
    distance_matrix = np.array(distance_matrix)
    
    # Calculate local density: average of distances to all neighbors
    neighbors = np.argwhere(distance_matrix > 0).flatten()
    local_density = np.mean(distance_matrix[neighbors])
    
    # Calculate global connectivity: reciprocal of average distance to all other nodes
    global_connectivity = 1 / np.mean(np.min(distance_matrix, axis=1))
    
    # Initialize the heuristic matrix with zeros
    heuristic_matrix = np.zeros(distance_matrix.shape)
    
    # Calculate heuristic for each edge
    for i in range(distance_matrix.shape[0]):
        for j in range(i+1, distance_matrix.shape[0]):
            # Edge weight (distance)
            edge_weight = distance_matrix[i, j]
            
            # Calculate position factor as the sum of distances of the edges connected to it
            position_factor = np.sum(distance_matrix[neighbors])
            
            # Combine local density, global connectivity, and position factor
            heuristic = (edge_weight - local_density) / global_connectivity + position_factor
            
            heuristic_matrix[i, j] = heuristic_matrix[j, i] = heuristic

    # Normalize heuristic values
    heuristic_matrix = (heuristic_matrix - np.min(heuristic_matrix)) / (np.max(heuristic_matrix) - np.min(heuristic_matrix))
    
    return heuristic_matrix
