            combined_path_length = (path_length_i + path_length_j) / 2

            # Consider neighbor pheromone levels
            neighbors_i = np.delete(np.arange(num_nodes), i)
            neighbors_j = np.delete(np.arange(num_nodes), j)
            heuristic_neighbor_i = np.mean(distance_matrix[neighbors_i]) if neighbors_i.size > 0 else 0
            heuristic_neighbor_j = np.mean(distance_matrix[neighbors_j]) if neighbors_j.size > 0 else 0
            combined_neighbor_phero = (heuristic_neighbor_i + heuristic_neighbor_j) / 2

            heuristic_matrix[i, j] = heuristic_matrix[j, i] = weighted_sum + combined_path_length + combined_neighbor_phero

    return heuristic_matrix
