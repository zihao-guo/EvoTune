    graph_expansion = np.sum(shortest_paths, axis=1)
    
    # Step 3: Novel scoring mechanism
    # Combine the original distance with the graph expansion to penalize longer distances and more central nodes
    heuristics_matrix = distance_matrix * (1 - graph_expansion / np.max(graph_expansion))
    
    return heuristics_matrix
