    learning_factor = 0.01  # Learning rate for dynamic weights

    # Initialize heuristic matrix with zeros
    heuristic_matrix = np.zeros_like(distance_matrix)

    # Calculate dynamic weights for each connection
    for i in range(num_nodes):
        for j in range(i+1, num_nodes):
            weight_i = connection_weights[0] * np.exp(learning_factor * np.sum(distance_matrix[i, :]))  # Learning factor for higher-weight connections
            weight_j = connection_weights[1] * np.exp(learning_factor * np.sum(distance_matrix[j, :]))
            weighted_sum = (distance_matrix[i, j] * weight_i) + (distance_matrix[i, j] * weight_j)

            # Consider the path length around the edge
