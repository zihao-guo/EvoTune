    local_density = np.mean(distance_matrix, axis=1)  # Average distance to other nodes

    # Initialize the heuristic matrix with the same shape as the input
    heuristics_matrix = np.ones_like(distance_matrix)

    # Calculate the eigenvector of the normalized adjacency matrix
    adj_matrix = (distance_matrix > 0).astype(int)  # Convert to binary adjacency matrix
    normalized_adj_matrix = adj_matrix / np.sum(adj_matrix, axis=1)[:, np.newaxis]  # Row normalization
    e_vec, _ = np.linalg.eig(normalized_adj_matrix)  # Eigenvectors and eigenvalues

    # Sort eigenvector components in descending order
    sorted_indices = np.argsort(np.abs(e_vec))[-n:][::-1]

    # Assign higher heuristic values to nodes with significant eigenvector components
    for i in range(n):
