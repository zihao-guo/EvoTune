        betweenness += betw

    # Degree Centrality
    degree = np.sum(distance_matrix > 0, axis=0)

    # Normalize Betweenness and Degree Centralities
    centrality = (betweenness / np.max(betweenness)) + (degree / np.max(degree))

    # Combine Betweenness and Degree Centrality with the original distance
    heuristic_matrix = distance_matrix + centrality[:, np.newaxis] - np.eye(num_nodes)

    return heuristic_matrix
