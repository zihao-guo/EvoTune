[INFO] Function that timed out: def heuristics(distance_matrix):
    num_nodes = distance_matrix.shape[0]
    heuristics_matrix = np.zeros_like(distance_matrix)

    # Step 1: Path Length Heuristic
    for i in range(num_nodes):
        total_path_length = np.sum(distance_matrix[i])  # Sum of distances to all nodes from i
        heuristics_matrix[i] = total_path_length

    # Step 2: Edge Importance Score
    # Create adjacency matrix
    adj_matrix = np.abs(np.diag(distance_matrix)) - distance_matrix  # Difference matrix
    edge_importance = adj_matrix.sum(axis=0) / np.sum(adj_matrix)  # Edge importance score

    # Step 3: Dynamic Programming Heuristic
    # Initialize shortest_path matrix
    shortest_paths = np.zeros((num_nodes, num_nodes))
    for i in range(num_nodes):
        shortest_paths[i, i] = 0  # Base case: distance to itself is 0
        for j in range(num_nodes):
            if i!= j:
                shortest_paths[i, j] = distance_matrix[i, j] + min(shortest_paths[j, k] for k in range(num_nodes) if adj_matrix[k, j]!= 0)

    # Calculate dynamic programming heuristic
    for i in range(num_nodes):
        for j in range(num_nodes):
            if i!= j:
                heuristics_matrix[i, j] = shortest_paths[i, j] - distance_matrix[i, j]

    return heuristics_matrix
