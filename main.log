    # Calculate total weight for each node (weighted by importance factor)
    total_weights = np.sqrt(np.sum(distance_matrix, axis=1))

    # Initialize the heuristics matrix with the same shape as the distance matrix
    heuristics_matrix = np.zeros_like(distance_matrix)

    # Fill the heuristics matrix
    for i in range(distance_matrix.shape[0]):
        for j in range(distance_matrix.shape[1]):
            if i == j:  # Self-loops have zero importance
                heuristics_matrix[i][j] = 0
            else:
                # Use Dijkstra's algorithm to find shortest path
                _, predecessors = dijkstra(csgraph=distance_matrix, directed=True, return_predecessors=True)
                
                # The heuristic for edge (i,j) is the product of direct distance and influence of its two nodes
                # Influence is determined by the total weight of nodes i and j (weighted by total weights)
                influence_i = total_weights[predecessors[i, j]] if predecessors[i, j]!= i else 0
                influence_j = total_weights[predecessors[j, i]] if predecessors[j, i]!= j else 0
                heuristics_matrix[i][j] = distance_matrix[i][j] * influence_i * influence_j

    return heuristics_matrix
