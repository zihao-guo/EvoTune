    # Get the number of vertices
    num_vertices = distance_matrix.shape[0]
    
    # Initialize the heuristic matrix with zeros
    heuristic_matrix = np.zeros(distance_matrix.shape)
    
    # Calculate the Bellman-Held-Karp heuristic for each edge
    for i in range(num_vertices):
        # Initialize the shortest path from i to all other nodes as positive infinity
        shortest_paths = np.full(num_vertices, float('inf'))
        shortest_paths[i] = 0
        
        # Relax the edges (i, j)
        for j in range(num_vertices):
