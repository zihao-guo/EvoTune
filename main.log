[INFO] Function that timed out: def heuristics(distance_matrix):
    n = distance_matrix.shape[0]
    importance_matrix = np.zeros((n, n))
    
    # Calculate edge importance by summing the minimum path distance from each node to the other
    for i in range(n):
        for j in range(i+1, n):
            importance_matrix[i, j] = min(distance_matrix[i, k] + distance_matrix[k, j] for k in range(n))
    
    # Connectivity factor
    connectivity_matrix = np.zeros((n, n))
    for i in range(n):
        for j in range(n):
            connectivity_matrix[i, j] = 1 / (1 + np.linalg.norm(distance_matrix[i, :] - distance_matrix[j, :]))
    
    # Combine edge importance and connectivity factors
    heuristics_matrix = importance_matrix + connectivity_matrix

    # Normalize the heuristics matrix
    heuristics_matrix = heuristics_matrix / np.sum(heuristics_matrix, axis=1)[:, None]

    return heuristics_matrix
