            for k in range(num_nodes):
                if k!= j:
                    cost_to_j = min(cost_to_j, distance_matrix[j, k] + distance_matrix[k, i])
            
            # Benefit-to-cost ratio
            ratio = benefit / (cost_from_i + cost_to_j)
            
            heuristics_matrix[i, j] = ratio

    # Apply a local scaling factor to penalize edges that contribute more to the overall path
    scaling_factor = 0.1  # This parameter can be tuned
    heuristics_matrix = heuristics_matrix - scaling_factor * np.max(heuristics_matrix) + scaling_factor

    return heuristics_matrix
