                    shortest_paths[j] = shortest_paths[k] + distance_matrix[k, j]
        
        # Calculate the heuristic score for node i
        heuristic_matrix[i, :] = shortest_paths[i] + np.sum(distance_matrix[i, :])
    
    return heuristic_matrix
