    n = distance_matrix.shape[0]
    
    # Heuristic 1: Penalize diagonal elements (self-distance)
    heuristics_matrix = np.zeros((n, n))
    np.fill_diagonal(heuristics_matrix, -np.sum(distance_matrix, axis=0))

    # Heuristic 2: Penalize nodes with high row sums (many connections)
    heuristics_matrix += (distance_matrix - np.min(distance_matrix, axis=1, keepdims=True))
    np.fill_diagonal(heuristics_matrix, 0)  # No penalty for self-distance in closeness

    # Heuristic 3: Closeness factor
    closeness_matrix = np.zeros((n, n))
