    num_nodes = distance_matrix.shape[0]
    heuristics_matrix = np.zeros_like(distance_matrix)

    for i in range(num_nodes):
        for j in range(i, num_nodes):  # Consider only unvisited nodes
            # Benefit: Edge weight
            benefit = distance_matrix[i, j]
            
            # Cost: Minimum path sum from i to all other nodes
            cost_from_i = np.inf
            for k in range(num_nodes):
                if k!= i:
                    cost_from_i = min(cost_from_i, distance_matrix[i, k] + distance_matrix[k, j])
            
            # Cost: Minimum path sum from j to all other nodes
